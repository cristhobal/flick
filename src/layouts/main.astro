---
import "@/styles/global.css"
import { TooltipProvider } from "@/components/ui/tooltip"
---

<html lang="en" class="dark" data-i18n-loading>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="canonical" href="https://flick.app/" />

    <!-- Primary Meta Tags -->
    <title>Flick — Tu plataforma personal de streaming</title>
    <meta name="title" content="Flick — Tu plataforma personal de streaming" />
    <meta name="description" content="Flick es tu plataforma para explorar películas, series y anime desde TMDB." />
    <meta name="theme-color" content="#000000" />
    <meta name="robots" content="index, follow" />
    <meta name="language" content="en" />

    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://flick.app/" />
    <meta property="og:title" content="Flick — Tu plataforma personal de streaming" />
    <meta property="og:description" content="Flick es tu plataforma para explorar películas, series y anime desde TMDB." />
    <meta property="og:image" content="https://flick.app/og-image.png" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:site_name" content="Flick" />
    <meta property="og:locale" content="en_US" />

    <!-- Twitter / X -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:url" content="https://flick.app/" />
    <meta name="twitter:title" content="Flick — Tu plataforma personal de streaming" />
    <meta name="twitter:description" content="Flick es tu plataforma para explorar películas, series y anime desde TMDB." />
    <meta name="twitter:image" content="https://flick.app/og-image.png" />

    <!-- JSON-LD Structured Data -->
    <script is:inline type="application/ld+json">
      {
        "@context": "https://schema.org",
        "@type": "WebApplication",
        "name": "Flick",
        "url": "https://flick.app/",
        "description": "Flick es tu plataforma para explorar películas, series y anime desde TMDB.",
        "applicationCategory": "Multimedia",
        "operatingSystem": "All",
        "author": {
          "@type": "Organization",
          "name": "Flick"
        },
        "offers": {
          "@type": "Offer",
          "price": "0"
        }
      }
    </script>
    <style is:global>
      html[data-i18n-loading] body { visibility: visible; }
    </style>
    <script is:inline>
      (function() {
        try {
          var supported = ["en", "es", "fr", "hi", "zh"]
          var stored = (localStorage.getItem("flick-lang") || "").split("-")[0].toLowerCase()
          var lang = supported.includes(stored) ? stored : (navigator.language || "").split("-")[0].toLowerCase()
          if (!supported.includes(lang)) lang = "en"
          localStorage.setItem("flick-lang", lang)
          document.documentElement.lang = lang
          document.cookie = "flick-lang=" + lang + "; path=/; max-age=31536000; samesite=lax"
          var localeMap = { en: "en_US", es: "es_MX", fr: "fr_FR", hi: "hi_IN", zh: "zh_CN" }
          var ogLocale = document.querySelector('meta[property="og:locale"]')
          if (ogLocale) ogLocale.setAttribute("content", localeMap[lang] || "en_US")
        } catch (_) {}
      })()
    </script>
  </head>
  <body class="min-h-screen bg-black text-white antialiased">
    <TooltipProvider>
      <slot />
    </TooltipProvider>
  </body>
</html>

